.btn:hover{transform:scale(1.08)}

.section-title{text-align:center;font-family:'Cinzel',serif;font-size:2.4rem;color:#cda52d;padding-top:20px;position:relative;z-index:2}
.review-card{width:300px}
.contact{text-align:center;padding:50px 20px;position:relative;z-index:2}
footer{text-align:center;padding:40px;color:#866600;line-height:2;position:relative;z-index:2}
@keyframes glow{from{text-shadow:0 0 10px rgba(212,175,55,.3)}to{text-shadow:0 0 35px rgba(212,175,55,.9)}}
</style>
