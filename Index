/* ETHEREAL BACKGROUND */
.star,.symbol{position:fixed;pointer-events:none;z-index:0;opacity:.25}
.star{color:#d4af37;animation:shoot linear infinite}
.symbol{animation:float 16s linear infinite;font-size:2rem}
@keyframes shoot{0%{transform:translate(-10vw,-10vh)}100%{transform:translate(120vw,120vh)}}
@keyframes float{0%{transform:translateY(100vh) rotate(0)}100%{transform:translateY(-120vh) rotate(360deg)}}

