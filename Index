.services,.reviews{padding:30px 20px 80px;display:flex;flex-wrap:wrap;justify-content:center;gap:28px;position:relative;z-index:2}
.card{
width:330px;background:rgba(255,255,255,.65);
border:2px solid rgba(212,175,55,.6);
border-radius:35px;padding:30px;text-align:center;
backdrop-filter:blur(16px);
box-shadow:0 0 35px rgba(212,175,55,.18);
transition:.45s ease;
}
.card:hover{transform:translateY(-10px) scale(1.03);box-shadow:0 0 50px rgba(212,175,55,.35)}
.card h2{font-family:'Cinzel',serif;margin-bottom:12px}
.price{font-size:1.7rem;font-weight:bold;margin:12px 0;color:#9a7300}
.desc{line-height:1.9;color:#715800}
.btn{
display:inline-block;margin-top:20px;padding:14px 25px;
background:linear-gradient(45deg,#d4af37,#fff4c2);
text-decoration:none;color:#6f5300;font-weight:bold;border-radius:20px;
transition:.3s;box-shadow:0 0 18px rgba(212,175,55,.4)
